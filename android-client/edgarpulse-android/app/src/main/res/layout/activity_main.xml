<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEC Filing Risk Tone Analyzer"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyze disclosure tone and recent filing activity"
            android:textSize="15sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/inputCik"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Enter SEC CIK (e.g., 0000320193)"
            android:inputType="number"
            android:maxLength="10"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="240dp"
            android:layout_height="56dp"
            android:text="Analyze Risk Tone"
            android:textSize="17sp"
            android:backgroundTint="#1E88E5"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCompanyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Company Name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvIndustry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Industry: N/A"
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFormType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analyzed Form: N/A"
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk Tone Score"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tvRiskScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="#F57C00"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRiskLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moderate Risk Tone"
                android:textSize="18sp"
                android:textStyle="italic"
                android:textColor="#F57C00"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvActivityLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disclosure Activity: N/A"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Summary will appear here."
                android:textSize="14sp"
                android:textColor="#616161"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>